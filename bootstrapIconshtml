<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Project Icons</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
.icon-box{
text-align:center;
padding:20px;
border:1px solid #ddd;
border-radius:10px;
transition:0.3s;
}

.icon-box:hover{
background:#f8f9fa;
transform:scale(1.05);
}

.icon-box i{
font-size:32px;
}
</style>

</head>

<body>

<div class="container mt-5">

<h2 class="text-center mb-4">Project Related Icons</h2>

<div class="row g-3">

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-speedometer2 text-primary"></i>
<p>Dashboard</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-person text-success"></i>
<p>User</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-people text-info"></i>
<p>User Management</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-gear text-warning"></i>
<p>Settings</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-database text-danger"></i>
<p>Database</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-file-earmark-text text-primary"></i>
<p>Reports</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-kanban text-success"></i>
<p>Projects</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-check2-square text-info"></i>
<p>Tasks</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-bell text-warning"></i>
<p>Notifications</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-chat-dots text-primary"></i>
<p>Messages</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-shield-lock text-danger"></i>
<p>Security</p>
</div>
</div>

<div class="col-md-3">
<div class="icon-box">
<i class="bi bi-bar-chart text-success"></i>
<p>Analytics</p>
</div>
</div>

</div>

</div>

</body>
</html>